{
  "name": "backend",
  "private": true,
  "version": "0.0.0",
  "description": "NestJS backend",
  "scripts": {
    "build": "nest build",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "smoke:forms": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-forms.ps1",
    "test": "cross-env DATABASE_URL=file:./test-unit.db jest --runInBand",
    "test:e2e": "cross-env DATABASE_URL=file:./test-e2e.db jest --config ./test/jest-e2e.json --runInBand",
    "test:ci": "npm run build && npm test && npm run test:e2e"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@prisma/client": "^5.22.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.11.30",
    "@types/supertest": "^6.0.2",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
